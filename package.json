{
  "name": "miru-time-tracking",
  "productName": "Miru Time Tracking",
  "version": "0.1.6",
  "description": "A local-first macOS desktop time tracking app for Miru teams.",
  "main": ".vite/build/main.js",
  "homepage": "https://app.miru.so",
  "packageManager": "bun@1.3.12",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saeloun/miru-time-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/saeloun/miru-time-desktop/issues"
  },
  "keywords": [
    "miru",
    "time-tracking",
    "electron",
    "macos",
    "desktop"
  ],
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:linux": "electron-forge make --platform=linux --arch=x64 --targets=@electron-forge/maker-zip",
    "make:mac": "bun run make:mac:apple && bun run make:mac:intel",
    "make:mac:apple": "electron-forge make --platform=darwin --arch=arm64 --targets=@electron-forge/maker-zip",
    "make:mac:intel": "electron-forge make --platform=darwin --arch=x64 --targets=@electron-forge/maker-zip",
    "make:windows": "electron-forge make --platform=win32 --arch=x64 --targets=@electron-forge/maker-zip",
    "publish": "electron-forge publish",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "bump-ui": "ts-node ./scripts/bump-ui.ts",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test"
  },
  "author": "Saeloun",
  "license": "MIT",
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@orpc/client": "^1.14.0",
    "@orpc/server": "^1.14.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.6",
    "@tanstack/react-router": "^1.168.25",
    "@tanstack/react-router-devtools": "^1.166.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-squirrel-startup": "^1.0.1",
    "i18next": "^26.0.8",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.6",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "update-electron-app": "^3.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@biomejs/biome": "^2.4.13",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron-forge/shared-types": "^7.11.1",
    "@electron/fuses": "^2.1.1",
    "@playwright/test": "^1.59.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tanstack/router-plugin": "^1.167.28",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__core": "^7.20.5",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "^41.3.0",
    "electron-devtools-installer": "^4.0.0",
    "electron-playwright-helpers": "^2.1.0",
    "globals": "^17.5.0",
    "jsdom": "^29.1.0",
    "tailwindcss": "^4.2.4",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "ultracite": "^7.6.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@electron/fuses": "^2.1.1",
    "@tootallnate/once": "^3.0.1",
    "tar": "^7.5.13",
    "tmp": "^0.2.5"
  }
}
